# AWS deploy credentials — copy to deploy/aws/.env.aws and fill in.
# NEVER commit the filled file.
#
# Load in Git Bash:
#   set -a && source deploy/aws/.env.aws && set +a
#   ./deploy/aws/ecs/configure-aws.sh
#
# Or export manually, then:
#   aws sts get-caller-identity

# ── Make `aws` work in this Git Bash session ──
# (AWS CLI installs here on Windows; PATH often misses it until you reopen the terminal)
export PATH="/c/Program Files/Amazon/AWSCLIV2:$PATH"

# ── AWS IAM access keys (IAM → Users → clawx-deploy → Security credentials → Create access key → CLI) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional session token (only if using temporary STS / SSO assumed role)
# AWS_SESSION_TOKEN=

# ── Region / deploy targets ──
AWS_DEFAULT_REGION=ap-south-1
AWS_REGION=ap-south-1
STACK_NAME=clawx-prod
PROJECT_NAME=clawx
ENVIRONMENT_NAME=prod
IMAGE_TAG=latest

# ── After HTTPS is set up (leave blank for first ALB-DNS-only smoke) ──
# CERT_ARN=arn:aws:acm:ap-south-1:ACCOUNT_ID:certificate/UUID
